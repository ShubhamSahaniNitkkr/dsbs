---
import media from '../../data/media.json';
import social from '../../data/social.json';
import { siteConfig, getWhatsAppConsultationUrl } from '../../lib/utils';
import RotatingMedia from '../ui/RotatingMedia';

const hero = media.hero;
const interval = media.settings.rotationIntervalMs;
---

<section class="hero-section relative overflow-hidden sm:min-h-[90vh] lg:min-h-screen">
  <div class="pointer-events-none absolute -top-24 right-0 h-72 w-72 rounded-full bg-rose-gold/10 blur-3xl" aria-hidden="true"></div>
  <div class="pointer-events-none absolute bottom-0 left-0 h-64 w-64 rounded-full bg-champagne/40 blur-3xl" aria-hidden="true"></div>

  <div class="container-salon relative grid items-center gap-8 px-5 pt-[6.25rem] pb-12 max-sm:gap-8 sm:gap-12 sm:px-0 sm:pt-24 sm:pb-16 lg:grid-cols-[1.05fr_0.95fr] lg:gap-14 lg:pt-28">
    <div class="hero-image-enter mx-auto w-full max-w-[17.5rem] max-sm:order-2 sm:max-w-lg lg:order-1 lg:max-w-none lg:justify-self-end">
      <div class="hero-frame hero-frame-glow">
        <RotatingMedia client:load items={hero.rotation} intervalMs={interval} aspectRatio="3/4" rounded={false} className="hero-rotator-lg" />
        <span class="hero-float-badge">{hero.badge}</span>
      </div>
    </div>

    <div class="hero-copy-enter max-sm:order-1 text-center lg:order-2 lg:text-left">
      <img
        src={media.logo}
        alt={media.logoAlt}
        class="mx-auto hidden h-16 w-auto object-contain sm:block lg:mx-0 lg:h-24"
        width="200"
        height="96"
      />

      <p class="label mt-0 sm:mt-6">{hero.overline}</p>
      <div class="divider mx-auto mt-3 lg:mx-0"></div>

      <h1 class="font-display mt-4 text-[1.75rem] font-semibold leading-[1.15] text-charcoal sm:mt-5 sm:text-4xl sm:leading-tight lg:text-[3.25rem]">
        <span class="hero-shimmer">{hero.titleLine1 || "Patna's Trusted"}</span><br />
        <span class="text-rose-gold-dark">{hero.titleLine2 || 'Bridal Makeup Artist'}</span>
      </h1>

      <p class="mx-auto mt-3 max-w-sm text-sm font-medium text-muted sm:mt-4 sm:text-base lg:mx-0">
        {siteConfig.stats.happyBrides}+ happy brides · Lakmé Certified · {hero.location}
      </p>

      {hero.philosophy && (
        <blockquote class="mx-auto mt-4 max-w-md border-l-2 border-rose-gold/50 pl-3 text-left text-xs italic leading-relaxed text-muted sm:mt-5 sm:pl-4 sm:text-sm lg:mx-0">
          {hero.philosophy}
        </blockquote>
      )}

      <p class="mx-auto mt-3 max-w-md text-xs leading-relaxed text-muted-light sm:mt-4 sm:text-sm lg:mx-0">
        {hero.description}
      </p>

      <div class="mt-6 flex flex-col gap-3 max-sm:mx-3 sm:mt-8 sm:mx-0 sm:flex-row sm:justify-center lg:justify-start">
        <a href={getWhatsAppConsultationUrl()} target="_blank" rel="noopener noreferrer" class="btn-whatsapp hero-cta-pulse">
          Book on WhatsApp
        </a>
        <a href="#transformations" class="btn-secondary">See Transformations</a>
      </div>

      <a
        href={social.instagram.url}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 inline-flex items-center gap-2 text-[11px] font-medium tracking-widest text-rose-gold-dark uppercase transition hover:text-rose-gold"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
        {social.instagram.handle}
      </a>
    </div>
  </div>
</section>
