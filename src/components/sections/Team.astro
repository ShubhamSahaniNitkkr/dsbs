---
import SectionTitle from '../ui/SectionTitle.astro';
import WorkInProgress from './WorkInProgress.astro';
import social from '../../data/social.json';
import media from '../../data/media.json';

const founder = media.team.find((m) => m.isFounder) || media.team[0];
---

<section id="team" class="section-padding bg-surface">
  <div class="container-salon">
    <SectionTitle label="The Artist" title={founder.name} subtitle={founder.role} />

    <div class="grid items-start gap-8 lg:grid-cols-2 lg:gap-12">
      <div class="hero-frame mx-auto w-full max-w-md lg:mx-0 lg:max-w-none">
        <img
          src={founder.image}
          alt={founder.name}
          class="aspect-[3/4] w-full object-cover object-top"
          loading="eager"
          width="600"
          height="800"
        />
      </div>
      <div class="text-center lg:text-left">
        {founder.certification && (
          <span class="badge-pill">{founder.certification}</span>
        )}
        {founder.philosophy && (
          <blockquote class="font-display mt-6 text-xl leading-relaxed text-charcoal sm:text-2xl">
            &ldquo;{founder.philosophy}&rdquo;
          </blockquote>
        )}
        <p class="mt-6 text-base leading-relaxed text-muted">{founder.bio}</p>
        {founder.instagram && (
          <a
            href={social.instagram.url}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-rose-gold-dark transition hover:text-rose-gold"
          >
            {founder.instagram}
          </a>
        )}
      </div>
    </div>

    <WorkInProgress />
  </div>
</section>
