---
import SectionTitle from '../ui/SectionTitle.astro';
import packages from '../../data/packages.json';
import type { Package } from '../../types';
import { getWhatsAppPackageUrl } from '../../lib/utils';

interface Props {
  featuredOnly?: boolean;
}

const { featuredOnly = false } = Astro.props;

const allPkgs = packages as Package[];
const pkgs = featuredOnly
  ? allPkgs.filter((p) => ['bridal-signature', 'royal-bride', 'luxury-wedding'].includes(p.id))
  : allPkgs;
---

<section id="packages" class="section-padding bg-surface-alt">
  <div class="container-salon">
    <SectionTitle
      label="Investment"
      title="Bridal Packages"
      subtitle="Premium products. Transparent pricing. Crafted for your wedding day."
    />

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 lg:gap-6">
      {pkgs.map((pkg) => (
        <article class:list={[
          'package-card flex flex-col p-6 sm:p-8',
          pkg.mostPopular ? 'package-card-popular' : 'salon-card',
        ]}>
          {pkg.mostPopular && (
            <span class="mb-4 inline-flex w-fit items-center gap-2 bg-rose-gold/10 px-3 py-1 text-[10px] font-semibold tracking-[0.2em] text-rose-gold uppercase">
              Most Booked
            </span>
          )}

          <p class="text-[10px] font-semibold tracking-[0.22em] text-muted uppercase">Package</p>
          <h3 class="font-display mt-2 text-xl font-semibold text-charcoal sm:text-2xl">{pkg.name}</h3>

          {pkg.description && (
            <p class="mt-3 text-sm leading-relaxed text-muted">{pkg.description}</p>
          )}

          <div class="mt-5 flex items-baseline gap-2 border-b border-champagne pb-5">
            <p class="font-display text-4xl font-semibold text-charcoal">
              ₹{pkg.price.toLocaleString('en-IN')}
            </p>
            {pkg.startingFrom && (
              <span class="text-[10px] tracking-widest text-muted uppercase">onwards</span>
            )}
          </div>

          <ul class="mt-5 flex-1 space-y-3">
            {pkg.includes.slice(0, 5).map((item) => (
              <li class="flex items-start gap-3 text-sm text-muted">
                <span class="mt-0.5 flex h-4 w-4 shrink-0 items-center justify-center rounded-full border border-rose-gold/40 text-[9px] text-rose-gold">✓</span>
                {item}
              </li>
            ))}
          </ul>

          <div class="mt-7 flex flex-col gap-2.5">
            <a href={getWhatsAppPackageUrl(pkg.name, pkg.price)} target="_blank" rel="noopener noreferrer" class="btn-whatsapp !text-[10px]">
              Book This Package
            </a>
            <a href={`#payment?package=${pkg.id}`} class="btn-secondary !text-[10px]">Reserve on WhatsApp</a>
          </div>
        </article>
      ))}
    </div>

    {featuredOnly && (
      <p class="mt-8 text-center text-sm text-muted">
        Engagement, Haldi, Reception & Party packages —
        <a href={getWhatsAppPackageUrl('Custom Package', 0)} class="text-rose-gold-dark underline" target="_blank" rel="noopener noreferrer"> ask on WhatsApp</a>
      </p>
    )}
  </div>
</section>

<script>
  const pkg = new URLSearchParams(window.location.hash.split('?')[1] || '').get('package');
  if (pkg) document.getElementById('payment')?.scrollIntoView({ behavior: 'smooth' });
</script>
