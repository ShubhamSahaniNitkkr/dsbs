---
/** Vertical DSBS logo-pattern watermark */
import media from '../../data/media.json';
---

<div class="watermark-layer" aria-hidden="true">
  <div class="watermark-columns">
    {Array.from({ length: 14 }).map(() => (
      <div class="watermark-column">
        {Array.from({ length: 10 }).map(() => (
          <img src={media.logo} alt="" class="watermark-logo" loading="lazy" decoding="async" />
        ))}
      </div>
    ))}
  </div>
</div>

<style>
  .watermark-layer {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .watermark-columns {
    display: flex;
    justify-content: space-evenly;
    align-items: stretch;
    width: 100%;
    height: 120%;
    position: absolute;
    top: -10%;
    left: 0;
    transform: rotate(-12deg);
  }

  .watermark-column {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-around;
    gap: 2.5rem;
    opacity: 0.042;
    flex-shrink: 0;
  }

  .watermark-logo {
    width: auto;
    height: clamp(0.9rem, 1.6vw, 1.15rem);
    object-fit: contain;
    transform: rotate(90deg);
    filter: saturate(1.15);
  }

  @media (min-width: 768px) {
    .watermark-column {
      gap: 3rem;
    }

    .watermark-logo {
      height: clamp(1rem, 1.4vw, 1.25rem);
    }
  }
</style>
