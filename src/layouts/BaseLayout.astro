---
import '../styles/global.css';
import Watermark from '../components/ui/Watermark.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import StickyWhatsApp from '../components/layout/StickyWhatsApp';
import FloatingCall from '../components/layout/FloatingCall';
import ExitIntentPopup from '../components/layout/ExitIntentPopup';
import SchemaMarkup from '../components/seo/SchemaMarkup.astro';
import { siteConfig } from '../lib/utils';
import media from '../data/media.json';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  canonical?: string;
  schemaType?: 'home' | 'service';
  serviceName?: string;
  serviceDescription?: string;
  noindex?: boolean;
}

const {
  title = siteConfig.seo?.title || `${siteConfig.brand} | ${siteConfig.tagline}`,
  description = siteConfig.seo?.description || `Lakmé certified bridal makeup artist in Patna. Book your consultation.`,
  keywords = siteConfig.seo?.keywords || 'bridal makeup patna, makeup artist patna',
  ogImage = siteConfig.seo?.ogImage || media.logo,
  canonical,
  schemaType = 'home',
  serviceName,
  serviceDescription,
  noindex = false,
} = Astro.props;

const canonicalUrl = canonical || Astro.url.href;
const cacheVersion = media.settings.cacheVersion;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteConfig.domain}${ogImage}`;
const siteName = siteConfig.brand;
const heroLcp = media.hero.rotation.find((item) => item.type === 'image')?.src;
---

<!doctype html>
<html lang="en-IN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={siteName} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'} />
    <meta name="geo.region" content="IN-BR" />
    <meta name="geo.placename" content="Patna" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="theme-color" content="#FAF7F4" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={siteName} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_IN" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- LLM / AI discovery -->
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM Site Summary" />
    <link rel="alternate" type="text/plain" href="/llms-full.txt" title="LLM Full Site Details" />

    <title>{title}</title>
    <link rel="icon" type="image/png" href={media.logo} />
    <link rel="apple-touch-icon" href={media.logo} />
    <link rel="preload" href={media.logo} as="image" />
    {heroLcp && <link rel="preload" href={heroLcp} as="image" fetchpriority="high" />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <SchemaMarkup type={schemaType} serviceName={serviceName} serviceDescription={serviceDescription} pageUrl={canonical} />
  </head>
  <body>
    <Watermark />
    <Header />
    <div class="site-content relative z-[1]">
      <main>
        <slot />
      </main>
      <Footer />
    </div>

    <StickyWhatsApp client:load />
    <FloatingCall client:load />
    <ExitIntentPopup client:idle />

    <script define:vars={{ cacheVersion }}>
      if ('serviceWorker' in navigator) {
        if (/localhost|127\.0\.0\.1/.test(location.hostname)) {
          navigator.serviceWorker.getRegistrations().then((regs) => regs.forEach((r) => r.unregister()));
        } else {
          window.addEventListener('load', () => {
            navigator.serviceWorker.register(`/sw.js?v=${cacheVersion}`).catch(() => {});
          });
        }
      }
    </script>
  </body>
</html>
